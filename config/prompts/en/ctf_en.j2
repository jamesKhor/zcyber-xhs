    "difficulty": "Easy / Medium / Hard",
    "engagement_cta": "Post your answer in the comments!"
  },
  "solution_body": "Solution reveal caption (120-180 words, announce the answer + walk through the reasoning + optional helper command, close with 'New challenge next Sunday')",
  "solution_image_text": {
    "headline": "Solution Revealed",
    "command": "Helper command if applicable, otherwise 'Solvable by hand'",
