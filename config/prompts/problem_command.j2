  "tags": ["#标签1", "#标签2", "#标签3", "#标签4", "#标签5"],
  "image_mode": "carousel",
  "image_template": "carousel_slide",
  "carousel_slides": [
    {
      "slide_type": "hook",
      "headline": "（≤15字，让读者觉得自己的设备现在就有这个问题）",
